{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "finalcall",
  "version": "0.1.0",
  "identifier": "com.krish.finalcall",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "finalcall",
        "width": 800,
        "height": 600
      },
      {
        "label": "mini",
        "title": "FinalCall Quick View",
        "width": 460,
        "height": 380,
        "resizable": false,
        "alwaysOnTop": true,
        "visible": false,
        "url": "/?mini=1"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
